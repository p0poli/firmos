<Window
    x:Class="FirmOS.Revit.ProjectSelectDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Select Project"
    Width="400" Height="300"
    WindowStyle="None"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    Background="#111111"
    Foreground="#FFFFFF"
    FontFamily="Segoe UI"
    FontSize="13">

    <Window.Resources>

        <!-- ComboBox shell — background/foreground of the closed control -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="#1a1a1a"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="BorderBrush"     Value="#222222"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="8,0"/>
        </Style>

        <!-- Primary (Confirm) button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="#5865f2"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="MinWidth"        Value="90"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4752c4"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary (Cancel) button -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#A1A1AA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="MinWidth"        Value="90"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- title bar   -->
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>  <!-- subtitle    -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>  <!-- combo label -->
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>  <!-- combo       -->
            <RowDefinition Height="*"/>     <!-- spacer      -->
            <RowDefinition Height="Auto"/>  <!-- buttons     -->
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    MouseDown="TitleBar_MouseDown">
            <TextBlock Text="Vitruvius"
                       FontSize="15"
                       FontWeight="Bold"
                       Foreground="#FFFFFF"
                       VerticalAlignment="Center"/>
            <TextBlock Text="  —  Link project"
                       FontSize="13"
                       Foreground="#A1A1AA"
                       VerticalAlignment="Center"/>
            <Button Content="✕"
                    Click="CancelBtn_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#A1A1AA"
                    Cursor="Hand"
                    Margin="140,0,0,0"
                    FontSize="12"
                    VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Subtitle -->
        <TextBlock Grid.Row="2"
                   Text="Choose the Vitruvius project to link this Revit model to."
                   Foreground="#A1A1AA"
                   FontSize="12"
                   TextWrapping="Wrap"/>

        <!-- ComboBox label -->
        <TextBlock Grid.Row="4"
                   Text="Project"
                   Foreground="#FFFFFF"
                   FontSize="11"/>

        <!-- Project picker -->
        <ComboBox Grid.Row="6"
                  x:Name="ProjectCombo"
                  DisplayMemberPath="Name"
                  SelectedValuePath="Id"
                  SelectionChanged="ProjectCombo_SelectionChanged">
            <!--
                ComboBoxItem style must live here (not in Window.Resources)
                because WPF's ComboBox popup has its own visual tree that does
                not inherit the window-level resource dictionary.
                Without this, items render with the system default theme colours
                (white background, dark text) regardless of window Foreground/Background.
            -->
            <ComboBox.Resources>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background"  Value="#1a1a1a"/>
                    <Setter Property="Foreground"  Value="#FFFFFF"/>
                    <Setter Property="Padding"     Value="8,6"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2a2a2a"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#5865f2"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ComboBox.Resources>
        </ComboBox>

        <!-- Action buttons -->
        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource SecondaryBtn}"
                    Margin="0,0,10,0"
                    Click="CancelBtn_Click"/>
            <Button x:Name="ConfirmBtn"
                    Content="Confirm"
                    Style="{StaticResource PrimaryBtn}"
                    IsEnabled="False"
                    Click="ConfirmBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
