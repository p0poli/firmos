<Window
    x:Class="FirmOS.Revit.ProjectSelectDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Select Project"
    Width="400" Height="300"
    WindowStyle="None"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    Background="#111111"
    Foreground="#E5E5E5"
    FontFamily="Segoe UI"
    FontSize="13">

    <Window.Resources>
        <!-- ComboBox style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"       Value="#1E1E1E"/>
            <Setter Property="Foreground"       Value="#E5E5E5"/>
            <Setter Property="BorderBrush"      Value="#3A3A3A"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Height"           Value="34"/>
            <Setter Property="Padding"          Value="8,0"/>
        </Style>

        <!-- Primary button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"       Value="#4F46E5"/>
            <Setter Property="Foreground"       Value="#FFFFFF"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Height"           Value="34"/>
            <Setter Property="MinWidth"         Value="90"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4338CA"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary button -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background"       Value="#2A2A2A"/>
            <Setter Property="Foreground"       Value="#AAAAAA"/>
            <Setter Property="BorderBrush"      Value="#3A3A3A"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Height"           Value="34"/>
            <Setter Property="MinWidth"         Value="90"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- title bar -->
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>  <!-- subtitle -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>  <!-- combo label -->
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>  <!-- combo -->
            <RowDefinition Height="*"/>     <!-- spacer -->
            <RowDefinition Height="Auto"/>  <!-- buttons -->
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    MouseDown="TitleBar_MouseDown">
            <TextBlock Text="Vitruvius"
                       FontSize="15"
                       FontWeight="Bold"
                       Foreground="#FFFFFF"
                       VerticalAlignment="Center"/>
            <TextBlock Text="  —  Link project"
                       FontSize="13"
                       Foreground="#888888"
                       VerticalAlignment="Center"/>
            <Button Content="✕"
                    Click="CancelBtn_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#888888"
                    Cursor="Hand"
                    Margin="140,0,0,0"
                    FontSize="12"
                    VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Subtitle -->
        <TextBlock Grid.Row="2"
                   Text="Choose the Vitruvius project to link this Revit model to."
                   Foreground="#888888"
                   FontSize="12"
                   TextWrapping="Wrap"/>

        <!-- ComboBox label -->
        <TextBlock Grid.Row="4"
                   Text="Project"
                   Foreground="#AAAAAA"
                   FontSize="11"/>

        <!-- Project picker -->
        <ComboBox Grid.Row="6"
                  x:Name="ProjectCombo"
                  DisplayMemberPath="Name"
                  SelectedValuePath="Id"
                  SelectionChanged="ProjectCombo_SelectionChanged"/>

        <!-- Action buttons -->
        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="10">
            <Button Content="Cancel"
                    Style="{StaticResource SecondaryBtn}"
                    Click="CancelBtn_Click"/>
            <Button x:Name="ConfirmBtn"
                    Content="Confirm"
                    Style="{StaticResource PrimaryBtn}"
                    IsEnabled="False"
                    Click="ConfirmBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
