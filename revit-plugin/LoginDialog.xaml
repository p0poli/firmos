<Window
    x:Class="FirmOS.Revit.LoginDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Sign in to Vitruvius"
    Width="360" Height="280"
    WindowStyle="None"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    Background="#111111"
    Foreground="#E5E5E5"
    FontFamily="Segoe UI"
    FontSize="13">

    <Window.Resources>
        <!-- Input field style -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background"           Value="#1E1E1E"/>
            <Setter Property="Foreground"           Value="#E5E5E5"/>
            <Setter Property="BorderBrush"          Value="#3A3A3A"/>
            <Setter Property="BorderThickness"      Value="1"/>
            <Setter Property="Padding"              Value="8,6"/>
            <Setter Property="Height"               Value="34"/>
            <Setter Property="CaretBrush"           Value="#E5E5E5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Password box style -->
        <Style x:Key="PasswordStyle" TargetType="PasswordBox">
            <Setter Property="Background"           Value="#1E1E1E"/>
            <Setter Property="Foreground"           Value="#E5E5E5"/>
            <Setter Property="BorderBrush"          Value="#3A3A3A"/>
            <Setter Property="BorderThickness"      Value="1"/>
            <Setter Property="Padding"              Value="8,6"/>
            <Setter Property="Height"               Value="34"/>
            <Setter Property="CaretBrush"           Value="#E5E5E5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Primary button style -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"       Value="#4F46E5"/>
            <Setter Property="Foreground"       Value="#FFFFFF"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Height"           Value="36"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4338CA"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- title bar -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>  <!-- email -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>  <!-- password -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>  <!-- button -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>  <!-- error -->
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    MouseDown="TitleBar_MouseDown">
            <TextBlock Text="Vitruvius"
                       FontSize="15"
                       FontWeight="Bold"
                       Foreground="#FFFFFF"
                       VerticalAlignment="Center"/>
            <TextBlock Text="  —  Sign in"
                       FontSize="13"
                       Foreground="#888888"
                       VerticalAlignment="Center"/>
            <Button Content="✕"
                    Click="CloseBtn_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#888888"
                    Cursor="Hand"
                    Margin="120,0,0,0"
                    FontSize="12"
                    VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Email -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Email"
                       Foreground="#AAAAAA"
                       FontSize="11"
                       Margin="0,0,0,4"/>
            <TextBox x:Name="EmailBox"
                     Style="{StaticResource InputStyle}"
                     KeyDown="Input_KeyDown"/>
        </StackPanel>

        <!-- Password -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="Password"
                       Foreground="#AAAAAA"
                       FontSize="11"
                       Margin="0,0,0,4"/>
            <PasswordBox x:Name="PasswordBox"
                         Style="{StaticResource PasswordStyle}"
                         KeyDown="Input_KeyDown"/>
        </StackPanel>

        <!-- Connect button -->
        <Button Grid.Row="6"
                x:Name="ConnectBtn"
                Content="Connect"
                Style="{StaticResource PrimaryBtn}"
                Click="ConnectBtn_Click"/>

        <!-- Error label -->
        <TextBlock Grid.Row="8"
                   x:Name="ErrorLabel"
                   Foreground="#F87171"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"/>
    </Grid>
</Window>
