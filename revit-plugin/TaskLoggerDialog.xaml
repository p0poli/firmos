<Window
    x:Class="FirmOS.Revit.TaskLoggerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Log Work — Vitruvius"
    Width="400"
    Height="540"
    MinWidth="340"
    MinHeight="480"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResize"
    Background="#1e1f22"
    Foreground="#dcddde"
    FontFamily="Segoe UI"
    FontSize="13"
    Closing="Window_Closing">

    <Window.Resources>
        <!-- Shared control styles -->
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#80848e"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="PrimaryLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#dcddde"/>
        </Style>

        <Style x:Key="MutedLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#80848e"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2b2d31"/>
            <Setter Property="Foreground" Value="#dcddde"/>
            <Setter Property="BorderBrush" Value="#40444b"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2b2d31"/>
            <Setter Property="Foreground" Value="#dcddde"/>
            <Setter Property="BorderBrush" Value="#40444b"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Green Start button -->
        <Style x:Key="StartBtn" TargetType="Button">
            <Setter Property="Background" Value="#22c55e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#16a34a"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Red Stop button -->
        <Style x:Key="StopBtn" TargetType="Button">
            <Setter Property="Background" Value="#ef4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#dc2626"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary (blue) Log button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#5865f2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4752c4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary (ghost) Cancel button -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#b5bac1"/>
            <Setter Property="BorderBrush" Value="#40444b"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2b2d31"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Duration stepper buttons -->
        <Style x:Key="StepperBtn" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="#2b2d31"/>
            <Setter Property="Foreground" Value="#dcddde"/>
            <Setter Property="BorderBrush" Value="#40444b"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#40444b"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!--
        DockPanel root: footer is docked to the Bottom so it is ALWAYS visible
        regardless of window height. The ScrollViewer fills remaining space.
    -->
    <DockPanel LastChildFill="True">

        <!-- ── Footer (always pinned) ── -->
        <Border DockPanel.Dock="Bottom"
                Background="#1e1f22"
                BorderBrush="#313338"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        x:Name="LogBtn"
                        Style="{StaticResource PrimaryBtn}"
                        Content="Log Work"
                        Click="LogBtn_Click"/>
                <Button Grid.Column="2"
                        x:Name="CancelBtn"
                        Style="{StaticResource SecondaryBtn}"
                        Content="Cancel"
                        Click="CancelBtn_Click"/>
            </Grid>
        </Border>

        <!-- ── Scrollable content ── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="20,20,20,12">

                <!-- Title -->
                <TextBlock Text="Log Work"
                           FontSize="17"
                           FontWeight="Bold"
                           Foreground="#dcddde"/>
                <TextBlock x:Name="SubtitleLabel"
                           Text="Start the timer or enter a duration manually."
                           Foreground="#80848e"
                           FontSize="11"
                           Margin="0,2,0,14"/>

                <!-- Task selector -->
                <TextBlock Text="Task" Style="{StaticResource Label}"/>
                <ComboBox x:Name="TaskCombo" DisplayMemberPath="Title" Margin="0,0,0,4">
                    <ComboBox.Resources>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Background" Value="#2b2d31"/>
                            <Setter Property="Foreground" Value="#dcddde"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#40444b"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#5865f2"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.Resources>
                </ComboBox>
                <TextBlock x:Name="NoTasksHint"
                           Text="No tasks assigned to you. Ask a project manager to assign tasks."
                           Foreground="#80848e"
                           FontSize="10"
                           Margin="0,2,0,0"
                           Visibility="Collapsed"/>

                <!-- Spacer -->
                <Border Height="16"/>

                <!-- Timer display -->
                <TextBlock x:Name="TimerDisplay"
                           Text="00:00:00"
                           FontFamily="Courier New"
                           FontSize="36"
                           FontWeight="Bold"
                           Foreground="White"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"/>

                <!-- Started-at label -->
                <TextBlock x:Name="StartedAtLabel"
                           Text=""
                           FontSize="11"
                           Foreground="#a1a1aa"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"
                           Visibility="Collapsed"/>

                <!-- Spacer -->
                <Border Height="8"/>

                <!-- Start / Stop button (full width) -->
                <Button x:Name="StartStopBtn"
                        Style="{StaticResource StartBtn}"
                        Content="&#x25B6;  Start Timer"
                        Click="StartStopBtn_Click"
                        Margin="0,0,0,14"/>

                <!-- Divider "or log manually" -->
                <Grid x:Name="DividerRow" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Height="1" Background="#313338" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text=" or log manually "
                               FontSize="10"
                               Foreground="#4e5058"
                               VerticalAlignment="Center"/>
                    <Border Grid.Column="2" Height="1" Background="#313338" VerticalAlignment="Center"/>
                </Grid>

                <!-- Manual section: duration stepper -->
                <StackPanel x:Name="ManualSection" Margin="0,0,0,12">
                    <TextBlock Text="Duration (minutes)" Style="{StaticResource Label}"/>
                    <StackPanel Orientation="Horizontal" Height="34">
                        <Button x:Name="MinusBtn" Style="{StaticResource StepperBtn}" Content="&#x2212;" Click="MinusBtn_Click"/>
                        <TextBox x:Name="DurationBox" Width="70" Margin="4,0" Text="30" TextAlignment="Center"/>
                        <Button x:Name="PlusBtn"  Style="{StaticResource StepperBtn}" Content="+" Click="PlusBtn_Click"/>
                        <TextBlock Text="min" Foreground="#80848e" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Notes -->
                <TextBlock Text="Notes (optional)" Style="{StaticResource Label}"/>
                <TextBox x:Name="NotesBox"
                         MinHeight="52"
                         MaxHeight="90"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"
                         Margin="0,0,0,12"/>

                <!-- Mark done -->
                <CheckBox x:Name="MarkDoneCheck"
                          Content="Mark task as done"
                          Foreground="#dcddde"
                          Margin="0,0,0,10"/>

                <!-- Confirmation toast -->
                <Border x:Name="ToastBorder"
                        Background="#14532d"
                        CornerRadius="4"
                        Padding="10,6"
                        Visibility="Collapsed">
                    <TextBlock x:Name="ToastLabel"
                               Foreground="#86efac"
                               FontSize="12"
                               TextAlignment="Center"/>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
