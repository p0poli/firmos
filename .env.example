DATABASE_URL=postgresql+psycopg2://firmos:firmos@db:5432/firmos
JWT_SECRET=change-me-in-production
SUPABASE_URL=
CORS_ORIGINS=http://localhost:3000
REACT_APP_API_URL=http://localhost:8000

# AI providers — system-wide fallback keys. A firm with its own key
# stored under firms.ai_api_key_encrypted (set via the Settings page)
# uses that instead of these env values. With both blank the AI service
# falls back to a deterministic stub response prefixed "[stub]".
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Fernet key for encrypting per-firm AI API keys at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# When unset, per-firm key storage is disabled (the env keys above are
# still used).
ENCRYPTION_KEY=
